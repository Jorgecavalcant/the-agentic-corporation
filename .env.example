# =============================================================================
# EMPRESA 100% IA - CONFIGURAÇÕES DE INSTALAÇÃO
# =============================================================================
# Instruções: 
# 1. Copie este arquivo para .env
# 2. Preencha seus dados reais
# 3. NUNCA suba o arquivo .env para o GitHub!
# =============================================================================

# CONFIGURAÇÕES DE ACESSO VPS
# Se você for instalar na sua VPS, informe o host SSH (usuário@ip_ou_dominio)
VPS_HOST=user@your_vps_ip

# CONFIGURAÇÕES DA EMPRESA (Opcional)
# O nome da empresa que será usado pelos agentes
COMPANY_NAME=Sua Empresa IA
CEO_NAME=Seu Nome

# CONFIGURAÇÕES DE INTERFACE
# O comando/nome usado para chamar o Orquestrador Master (Ex: jc, /jc, manager)
# Para acionar o agente padrão, basta falar: "Agent Manager" ou "/jc"
ORCHESTRATOR_TRIGGER=jc
